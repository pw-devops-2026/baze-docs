{
  "openapi": "3.0.1",
  "info": {
    "title": "Vidu 参考生图",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://baze-api.powerbuyin.top"
    }
  ],
  "paths": {
    "/vidu/v1/images/reference2image": {
      "post": {
        "summary": "Vidu 参考生图",
        "operationId": "viduReferenceToImage",
        "description": "使用 Vidu 模型基于参考图片生成新图片。提交任务后，请通过 `GET /vidu/v1/{task_id}` 查询状态。",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReferenceToImageRequest"
              },
              "examples": {
                "text_to_image": {
                  "summary": "纯文本生图（viduq2）",
                  "value": {
                    "model": "viduq2",
                    "prompt": "一只可爱的小猫在草地上玩耍，阳光明媚",
                    "aspect_ratio": "16:9",
                    "resolution": "4K",
                    "seed": 42
                  }
                },
                "reference_to_image": {
                  "summary": "参考图片生图",
                  "value": {
                    "model": "viduq2",
                    "images": [
                      "https://example.com/reference1.png",
                      "https://example.com/reference2.png"
                    ],
                    "prompt": "保持角色风格，生成一张新的场景图",
                    "aspect_ratio": "1:1",
                    "resolution": "2K"
                  }
                },
                "image_editing": {
                  "summary": "图片编辑",
                  "value": {
                    "model": "viduq2",
                    "images": [
                      "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAE..."
                    ],
                    "prompt": "将背景改为夜晚星空，添加月亮",
                    "aspect_ratio": "auto",
                    "resolution": "1080p"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "提交成功，返回图片任务对象。"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ReferenceToImageRequest": {
        "type": "object",
        "required": [
          "model",
          "prompt"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "viduq2"
            ],
            "description": "图片生成模型名称。\n- **viduq2**: 支持文生图、图片编辑、参考生图，效果更佳"
          },
          "images": {
            "type": "array",
            "minItems": 0,
            "maxItems": 7,
            "items": {
              "type": "string"
            },
            "description": "参考图片列表。\n- **viduq2**: 支持输入 0-7 张图片\n- **viduq1**: 支持输入 1-7 张图片\n模型将基于输入的图片生成具有相同主体的新图片。\n注意事项：\n- 支持 Base64 或 URL 格式（URL 必须可访问）\n- 支持格式：png, jpeg, jpg, webp\n- 图片分辨率不得小于 128×128\n- 宽高比必须在 1:4 到 4:1 之间\n- 单张图片大小不得超过 50MB\n- HTTP 请求体不得超过 20MB，且编码必须包含适当的内容类型字符串\n- Base64 格式示例：`data:image/png;base64,{base64_encode}`"
          },
          "prompt": {
            "type": "string",
            "maxLength": 2000,
            "description": "文本提示词，用于描述图片生成内容，最大长度 2000 字符。\n注意：viduq2 支持仅使用 prompt 生成图片（无需提供参考图片）。"
          },
          "seed": {
            "type": "integer",
            "description": "随机种子。\n- 默认为随机种子数\n- 手动设置值将覆盖默认随机种子"
          },
          "aspect_ratio": {
            "type": "string",
            "enum": [
              "16:9",
              "9:16",
              "1:1",
              "3:4",
              "4:3",
              "21:9",
              "2:3",
              "3:2",
              "auto"
            ],
            "default": "16:9",
            "description": "图片宽高比。\n- **viduq1**: 默认 16:9，可选值：16:9, 9:16, 1:1, 3:4, 4:3\n- **viduq2**: 默认 16:9，可选值：16:9, 9:16, 1:1, 3:4, 4:3, 21:9, 2:3, 3:2\n- **auto**: 生成的图片宽高比与第一张输入图片保持一致"
          },
          "resolution": {
            "type": "string",
            "enum": [
              "1080p",
              "2K",
              "4K"
            ],
            "default": "1080p",
            "description": "图片分辨率。\n- **viduq1**: 默认 1080p，可选值：1080p\n- **viduq2**: 默认 1080p，可选值：1080p, 2K, 4K"
          },
          "payload": {
            "type": "string",
            "maxLength": 1048576,
            "description": "透传参数。\n不做处理，仅做数据透传，最大长度 1048576 字符。"
          }
        }
      }
    }
  }
}
