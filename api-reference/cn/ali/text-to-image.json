{
  "openapi": "3.0.1",
  "info": {
    "title": "Qwen 文生图",
    "version": "1.0.0",
    "description": "Qwen 图像生成能力文档。公开统一入口为 `/v1/images/generations`，用于根据文本提示词生成图片。",
    "license": {
      "name": "Project License",
      "url": "https://github.com/QuantumNous/new-api/blob/main/LICENSE"
    }
  },
  "servers": [
    {
      "url": "https://baze-api.powerbuyin.top",
      "description": "Baze API 服务地址"
    }
  ],
  "tags": [
    {
      "name": "Qwen Image",
      "description": "Qwen 图像生成能力"
    }
  ],
  "paths": {
    "/v1/images/generations": {
      "post": {
        "summary": "Qwen 文生图",
        "description": "适用于 Qwen 图像生成模型的文生图能力。\n\n支持模型包括 `qwen-image-2.0-pro`、`qwen-image-2.0`、`qwen-image-max`、`qwen-image-plus`、`qwen-image` 等。公开字段：`model`、`prompt`、`n`、`size`、`response_format`、`seed`、`watermark`、`prompt_extend`、`negative_prompt`。",
        "operationId": "aliTextToImage",
        "tags": [
          "Qwen Image"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextToImageRequest"
              },
              "examples": {
                "basic_request": {
                  "summary": "基础文生图请求",
                  "value": {
                    "model": "qwen-image-2.0-pro",
                    "prompt": "一只可爱的橘猫坐在窗台上，阳光洒在身上，写实风格",
                    "n": 1,
                    "size": "1024*1024",
                    "response_format": "url"
                  }
                },
                "advanced_request": {
                  "summary": "高级参数请求",
                  "value": {
                    "model": "qwen-image-2.0-pro",
                    "prompt": "科幻风格的城市夜景，霓虹灯光，未来感建筑",
                    "n": 2,
                    "size": "2048*1024",
                    "negative_prompt": "低分辨率，低画质，畸形，模糊",
                    "prompt_extend": true,
                    "watermark": false,
                    "seed": 42,
                    "response_format": "url"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "调用成功，返回图像生成结果。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResponse"
                }
              }
            }
          },
          "400": {
            "description": "请求参数不合法。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "TextToImageRequest": {
        "type": "object",
        "required": [
          "model",
          "prompt"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "qwen-image-2.0-pro",
              "qwen-image-2.0-pro-2026-03-03",
              "qwen-image-2.0",
              "qwen-image-2.0-2026-03-03",
              "qwen-image-max",
              "qwen-image-max-2025-12-30",
              "qwen-image-plus",
              "qwen-image-plus-2026-01-09",
              "qwen-image"
            ],
            "description": "千问图像模型名称。"
          },
          "prompt": {
            "type": "string",
            "description": "图像生成提示词，描述期望生成的图像内容、风格和构图。支持中英文，长度不超过 800 个字符。"
          },
          "n": {
            "type": "integer",
            "description": "生成图像的数量。qwen-image-2.0 系列支持 1-6 张，其他模型固定为 1。",
            "minimum": 1,
            "maximum": 6,
            "default": 1
          },
          "size": {
            "type": "string",
            "description": "输出图像分辨率，格式为 `宽*高`。\nqwen-image-2.0 系列：总像素需在 512*512 至 2048*2048 之间。\nqwen-image-max/plus 系列：支持 1664*928(16:9)、1472*1104(4:3)、1328*1328(1:1)、1104*1472(3:4)、928*1664(9:16)",
            "example": "1024*1024"
          },
          "response_format": {
            "type": "string",
            "enum": [
              "url",
              "b64_json"
            ],
            "description": "响应格式。url 返回图片下载链接，b64_json 返回 Base64 编码的图片数据。",
            "default": "url"
          },
          "seed": {
            "type": "integer",
            "description": "随机数种子，取值范围 [0, 2147483647]。使用相同种子可生成相似结果。"
          },
          "watermark": {
            "type": "boolean",
            "description": "是否在图像右下角添加水印。",
            "default": false
          },
          "prompt_extend": {
            "type": "boolean",
            "description": "是否开启提示词智能改写。开启后会自动优化输入提示词。",
            "default": true
          },
          "negative_prompt": {
            "type": "string",
            "description": "反向提示词，描述不希望在图像中出现的内容。支持中英文，长度不超过 500 个字符。"
          }
        }
      },
      "ImageResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "format": "int64",
            "description": "创建时间的 Unix 时间戳（秒）。"
          },
          "data": {
            "type": "array",
            "description": "生成的图像列表。",
            "items": {
              "$ref": "#/components/schemas/ImageData"
            }
          },
          "metadata": {
            "type": "object",
            "description": "附加结果信息。字段内容会随能力不同而变化。"
          }
        }
      },
      "ImageData": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "图片下载链接。有效期 24 小时，请及时保存。"
          },
          "b64_json": {
            "type": "string",
            "description": "Base64 编码的图片数据。当 response_format=b64_json 时返回。"
          },
          "revised_prompt": {
            "type": "string",
            "description": "优化后的提示词（当开启 prompt_extend 时）。"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "code": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
