{
  "openapi": "3.0.1",
  "info": {
    "title": "阿里语音合成",
    "version": "1.0.0",
    "description": "阿里通道语音合成能力文档。公开统一入口为 `/v1/audio/speech`，当前项目已实现 `qwen3-tts-instruct-flash` 的官方字段子集。\n\n本文档只描述项目当前已实现、且与阿里官方能力一致的字段：`model`、`input`、`voice`、`instructions`、`optimize_instructions`、`language_type`、`stream_format`。\n\n在统一入口中，`stream_format` 既承担“开启流式输出”的作用，也会继续作为阿里上游需要的流式编码值透传。也就是说，任何非空 `stream_format` 都会被视为流式请求。\n\n项目计费说明：网关会把上游 `usage.characters` 映射到统一 usage 的 `prompt_tokens_details.audio_tokens`，并保留 `usage.output_tokens -> usage.completion_tokens_details.audio_tokens`；当 Internal Pricing 配置 `quota_type=3` 时，最终按统一输入音频字符数结算。"
  },
  "servers": [
    {
      "url": "https://baze-api.powerbuyin.top",
      "description": "Baze API 服务地址"
    }
  ],
  "tags": [
    {
      "name": "Ali Audio",
      "description": "阿里语音合成能力"
    }
  ],
  "paths": {
    "/v1/audio/speech": {
      "post": {
        "summary": "阿里语音合成",
        "description": "调用阿里 `qwen3-tts-instruct-flash` 生成语音。\n\n响应约定：\n- 非流式固定返回 `302 Found + Location`；\n- 流式固定返回 `text/event-stream`，透传阿里 SSE 数据。",
        "operationId": "aliAudioSpeech",
        "tags": [
          "Ali Audio"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AliSpeechRequest"
              },
              "examples": {
                "basic": {
                  "summary": "非流式请求",
                  "value": {
                    "model": "qwen3-tts-instruct-flash",
                    "input": "请用略快的语速介绍这款产品。",
                    "voice": "Cherry",
                    "instructions": "语速较快，带有上扬语调。",
                    "optimize_instructions": false,
                    "language_type": "Chinese"
                  }
                },
                "stream": {
                  "summary": "流式请求",
                  "value": {
                    "model": "qwen3-tts-instruct-flash",
                    "input": "Today is a wonderful day to build something people love.",
                    "voice": "Cherry",
                    "language_type": "English",
                    "stream_format": "pcm"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "流式调用成功，返回阿里 SSE 数据。项目内部结算会读取 `usage.characters` 作为统一输入音频字符数。",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "302": {
            "description": "非流式调用成功。`Location` 头为音频文件临时下载地址。项目内部结算会读取 `usage.characters` 作为统一输入音频字符数。",
            "headers": {
              "Location": {
                "schema": {
                  "type": "string",
                  "format": "uri"
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API Token"
      }
    },
    "schemas": {
      "AliSpeechRequest": {
        "type": "object",
        "required": [
          "model",
          "input",
          "voice"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "qwen3-tts-instruct-flash"
            ]
          },
          "input": {
            "type": "string",
            "description": "待合成文本。"
          },
          "voice": {
            "type": "string",
            "description": "音色名称。"
          },
          "instructions": {
            "type": "string",
            "description": "风格控制指令。"
          },
          "optimize_instructions": {
            "type": "boolean",
            "description": "是否优化 `instructions`。显式 `false` 也会保留并透传。"
          },
          "language_type": {
            "type": "string",
            "description": "语言类型。"
          },
          "stream_format": {
            "type": "string",
            "description": "流式输出格式。任何非空值都会触发统一入口的流式请求；当前阿里能力常用值为 `pcm`。"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorObject"
          }
        }
      },
      "ErrorObject": {
        "type": "object",
        "required": [
          "message",
          "type",
          "param",
          "code"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "param": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      }
    }
  }
}
