{
  "openapi": "3.0.1",
  "info": {
    "title": "Seedream 图像生成",
    "version": "1.0.0",
    "description": "Seedream 系列图像能力文档。公开统一入口为 `/v1/images/generations`，覆盖文生图、图生图与组图生成场景。",
    "license": {
      "name": "Project License",
      "url": "https://github.com/QuantumNous/new-api/blob/main/LICENSE"
    }
  },
  "servers": [
    {
      "url": "https://baze-api.powerbuyin.top",
      "description": "Baze API 服务地址"
    }
  ],
  "tags": [
    {
      "name": "Seedream Image",
      "description": "Seedream 系列图像生成能力"
    }
  ],
  "paths": {
    "/v1/images/generations": {
      "post": {
        "summary": "Seedream 图像生成",
        "description": "适用于 Seedream 系列图像模型。\n\n支持 `doubao-seedream-5.0-lite`、`doubao-seedream-4.5`、`doubao-seedream-4.0`、`doubao-seedream-3.0-t2i`、`doubao-seededit-3.0-i2i`。公开字段：`model`、`prompt`、`image`、`size`、`seed`、`sequential_image_generation`、`n`、`response_format`、`watermark`。生成结果链接通常为临时地址，请及时下载保存。",
        "operationId": "byteplusImageGenerations",
        "tags": [
          "Seedream Image"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageGenerationRequest"
              },
              "examples": {
                "text_to_image": {
                  "summary": "文生图",
                  "value": {
                    "model": "doubao-seedream-4.5",
                    "prompt": "一只可爱的柯基犬在草地上奔跑，阳光明媚，写实风格",
                    "size": "2048x2048",
                    "response_format": "url"
                  }
                },
                "image_to_image": {
                  "summary": "图生图",
                  "value": {
                    "model": "doubao-seedream-4.5",
                    "prompt": "将图片转换为宫崎骏动画风格",
                    "image": "https://example.com/input.jpg",
                    "size": "2048x2048"
                  }
                },
                "sequential_images": {
                  "summary": "组图生成",
                  "value": {
                    "model": "doubao-seedream-4.5",
                    "prompt": "一套四季风景插画，春夏秋冬",
                    "sequential_image_generation": "auto",
                    "response_format": "url"
                  }
                },
                "multi_image_reference": {
                  "summary": "多图参考生成",
                  "value": {
                    "model": "doubao-seedream-4.5",
                    "prompt": "结合这些图片的风格，生成一张新的风景图",
                    "image": [
                      "https://example.com/ref1.jpg",
                      "https://example.com/ref2.jpg"
                    ],
                    "n": 3
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "调用成功，返回图像生成结果。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageGenerationResponse"
                }
              }
            }
          },
          "400": {
            "description": "请求参数不合法。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ImageGenerationRequest": {
        "type": "object",
        "required": [
          "model",
          "prompt"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "doubao-seedream-5.0-lite",
              "doubao-seedream-4.5",
              "doubao-seedream-4.0",
              "doubao-seedream-3.0-t2i",
              "doubao-seededit-3.0-i2i"
            ],
            "description": "图像生成模型名称。seedream-5.0-lite/4.5/4.0 支持组图功能，seedream-3.0-t2i 仅支持文生图，seededit-3.0-i2i 支持图生图。"
          },
          "prompt": {
            "type": "string",
            "description": "图像生成提示词。建议不超过 300 个汉字或 600 个英文单词。"
          },
          "image": {
            "anyOf": [
              {
                "type": "string",
                "description": "单张参考图片 URL 或 Base64 编码。"
              },
              {
                "type": "array",
                "description": "多张参考图片（2-14 张），用于多图融合/组图生成。",
                "items": {
                  "type": "string"
                },
                "minItems": 1,
                "maxItems": 14
              }
            ],
            "description": "参考图片。seedream-5.0-lite/4.5/4.0 支持 1-14 张，seededit-3.0-i2i 仅支持 1 张，seedream-3.0-t2i 不支持。"
          },
          "n": {
            "type": "integer",
            "description": "生成图像数量。当 sequential_image_generation=auto 时，模型自动决定数量（最多 15 张，含参考图）。",
            "minimum": 1,
            "maximum": 15,
            "default": 1
          },
          "size": {
            "type": "string",
            "description": "输出图像尺寸。\n- seedream-5.0-lite：支持 2K/3K 或自定义（总像素 3686400-10404496，宽高比 1/16-16）\n- seedream-4.5：支持 2K/4K 或自定义（总像素 3686400-16777216，宽高比 1/16-16）\n- seedream-4.0：支持 1K/2K/4K 或自定义（总像素 921600-16777216，宽高比 1/16-16）\n- seedream-3.0-t2i/seededit-3.0-i2i：总像素 512x512 至 2048x2048，宽高比 1/3-3",
            "example": "2048x2048"
          },
          "response_format": {
            "type": "string",
            "enum": [
              "url",
              "b64_json"
            ],
            "description": "响应格式。",
            "default": "url"
          },
          "seed": {
            "type": "integer",
            "description": "随机数种子。仅 seedream-3.0-t2i 和 seededit-3.0-i2i 支持。取值范围 [-1, 2147483647]。",
            "default": -1
          },
          "sequential_image_generation": {
            "type": "string",
            "enum": [
              "auto",
              "disabled"
            ],
            "description": "组图功能开关。auto 为自动判断模式，disabled 为关闭组图（仅生成单图）。仅 seedream-5.0-lite/4.5/4.0 支持。",
            "default": "disabled"
          },
          "watermark": {
            "type": "boolean",
            "description": "是否添加水印。",
            "default": true
          }
        }
      },
      "ImageGenerationResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "format": "int64",
            "description": "创建时间的 Unix 时间戳（秒）。"
          },
          "data": {
            "type": "array",
            "description": "生成的图像列表。组图场景下可能包含多张图片。",
            "items": {
              "$ref": "#/components/schemas/ImageData"
            }
          },
          "metadata": {
            "type": "object",
            "description": "附加结果信息。字段内容会随能力不同而变化。"
          }
        }
      },
      "ImageData": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "图片下载链接。有效期 24 小时，请及时保存。"
          },
          "b64_json": {
            "type": "string",
            "description": "Base64 编码的图片数据。"
          },
          "size": {
            "type": "string",
            "description": "图像尺寸（宽x高）。仅 seedream-5.0-lite/4.5/4.0 返回。"
          },
          "error": {
            "type": "object",
            "description": "单张图片生成错误信息。",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "code": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
