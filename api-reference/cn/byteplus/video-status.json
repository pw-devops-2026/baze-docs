{
  "openapi": "3.0.1",
  "info": {
    "title": "视频任务状态查询",
    "version": "1.0.0",
    "description": "异步视频任务状态查询文档。公开统一入口为 `/v1/videos/{task_id}`，用于查询任务状态、进度与结果。",
    "license": {
      "name": "Project License",
      "url": "https://github.com/QuantumNous/new-api/blob/main/LICENSE"
    }
  },
  "servers": [
    {
      "url": "https://baze-api.powerbuyin.top",
      "description": "Baze API 服务地址"
    }
  ],
  "tags": [
    {
      "name": "Seedance Video",
      "description": "Seedance 视频任务状态查询"
    }
  ],
  "paths": {
    "/v1/videos/{task_id}": {
      "get": {
        "summary": "视频任务状态查询",
        "description": "根据任务 ID 查询异步视频任务的最新状态。\n\n状态流转通常为 `queued -> running -> succeeded/failed/expired`。当前仅支持查询最近 7 天内创建的任务。",
        "operationId": "byteplusQueryVideoStatus",
        "tags": [
          "Seedance Video"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "视频生成任务 ID。"
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功，返回任务状态。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoTaskQueryResponse"
                },
                "examples": {
                  "queued": {
                    "summary": "排队中",
                    "value": {
                      "id": "cgt-20250331175019-68d9t",
                      "task_id": "cgt-20250331175019-68d9t",
                      "object": "video",
                      "model": "doubao-seedance-1-5-pro-251215",
                      "status": "queued",
                      "progress": 0,
                      "created_at": 1742515200
                    }
                  },
                  "running": {
                    "summary": "处理中",
                    "value": {
                      "id": "cgt-20250331175019-68d9t",
                      "task_id": "cgt-20250331175019-68d9t",
                      "object": "video",
                      "model": "doubao-seedance-1-5-pro-251215",
                      "status": "running",
                      "progress": 45,
                      "created_at": 1742515200
                    }
                  },
                  "succeeded": {
                    "summary": "成功",
                    "value": {
                      "id": "cgt-20250331175019-68d9t",
                      "task_id": "cgt-20250331175019-68d9t",
                      "object": "video",
                      "model": "doubao-seedance-1-5-pro-251215",
                      "status": "succeeded",
                      "progress": 100,
                      "created_at": 1742515200,
                      "completed_at": 1742515500,
                      "video_url": "https://example.com/videos/output.mp4",
                      "metadata": {
                        "generate_audio": true,
                        "draft": false,
                        "resolution": "720p",
                        "ratio": "16:9",
                        "duration": 5,
                        "frames": 120,
                        "framespersecond": 24
                      }
                    }
                  },
                  "failed": {
                    "summary": "失败",
                    "value": {
                      "id": "cgt-20250331175019-68d9t",
                      "task_id": "cgt-20250331175019-68d9t",
                      "object": "video",
                      "model": "doubao-seedance-1-5-pro-251215",
                      "status": "failed",
                      "progress": 0,
                      "created_at": 1742515200,
                      "completed_at": 1742515300,
                      "metadata": {
                        "error": {
                          "code": "InvalidParameter",
                          "message": "Invalid parameter value"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "任务不存在或已过期（超过7天）。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "VideoTaskQueryResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "视频生成任务 ID。"
          },
          "task_id": {
            "type": "string",
            "description": "任务 ID（与 id 相同）。"
          },
          "object": {
            "type": "string",
            "example": "video"
          },
          "model": {
            "type": "string",
            "description": "使用的模型名称。"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "queued",
              "running",
              "succeeded",
              "failed",
              "cancelled",
              "expired"
            ],
            "description": "任务状态。queued: 排队中; running: 处理中; succeeded: 成功; failed: 失败; cancelled: 已取消; expired: 超时。"
          },
          "progress": {
            "type": "integer",
            "description": "任务进度（百分比）。",
            "minimum": 0,
            "maximum": 100
          },
          "created_at": {
            "type": "integer",
            "format": "int64",
            "description": "创建时间的 Unix 时间戳（秒）。"
          },
          "updated_at": {
            "type": "integer",
            "format": "int64",
            "description": "状态更新时间的 Unix 时间戳（秒）。"
          },
          "completed_at": {
            "type": "integer",
            "format": "int64",
            "description": "完成时间的 Unix 时间戳（秒），仅在成功或失败时返回。"
          },
          "video_url": {
            "type": "string",
            "description": "生成视频的下载链接。有效期 24 小时，请及时保存。仅在状态为 succeeded 时返回。"
          },
          "last_frame_url": {
            "type": "string",
            "description": "视频尾帧图像 URL。有效期 24 小时。仅当创建任务时 return_last_frame=true 时返回。"
          },
          "metadata": {
            "type": "object",
            "description": "任务的详细元数据。",
            "properties": {
              "generate_audio": {
                "type": "boolean",
                "description": "是否生成了音频。仅 Seedance 1.5 pro 返回。"
              },
              "draft": {
                "type": "boolean",
                "description": "是否为样片（Draft）视频。仅 Seedance 1.5 pro 返回。"
              },
              "draft_task_id": {
                "type": "string",
                "description": "样片任务 ID。基于样片生成正式视频时返回。"
              },
              "resolution": {
                "type": "string",
                "description": "实际生成的分辨率。"
              },
              "ratio": {
                "type": "string",
                "description": "实际生成的宽高比。"
              },
              "duration": {
                "type": "integer",
                "description": "实际生成的时长（秒）。未指定 frames 时返回 duration。"
              },
              "frames": {
                "type": "integer",
                "description": "实际生成的帧数。指定了 frames 时返回。"
              },
              "framespersecond": {
                "type": "integer",
                "description": "生成视频的帧率。"
              },
              "service_tier": {
                "type": "string",
                "description": "实际使用的服务等级。default: 在线推理; flex: 离线推理。"
              },
              "execution_expires_after": {
                "type": "integer",
                "description": "任务超时阈值（秒）。"
              },
              "error": {
                "type": "object",
                "description": "错误信息（任务失败时）。",
                "properties": {
                  "code": {
                    "type": "string",
                    "description": "错误码。"
                  },
                  "message": {
                    "type": "string",
                    "description": "错误信息。"
                  }
                }
              },
              "usage": {
                "type": "object",
                "description": "Token 用量统计。",
                "properties": {
                  "completion_tokens": {
                    "type": "integer",
                    "description": "模型输出视频花费的 token 数量。"
                  },
                  "total_tokens": {
                    "type": "integer",
                    "description": "总 token 数量（等于 completion_tokens）。"
                  }
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "code": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
