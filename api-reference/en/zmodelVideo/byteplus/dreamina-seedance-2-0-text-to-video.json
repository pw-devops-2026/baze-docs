{
  "openapi": "3.0.1",
  "info": {
    "title": "Seedance 2.0 Text-to-Video",
    "version": "1.0.0",
    "description": "Dreamina Seedance 2.0 text-to-video capability. Generates high-quality videos from text prompts.",
    "license": {
      "name": "Project License",
      "url": "https://github.com/QuantumNous/new-api/blob/main/LICENSE"
    }
  },
  "servers": [
    {
      "url": "https://api.powertokens.ai",
      "description": "Baze API server endpoint"
    }
  ],
  "tags": [
    {
      "name": "Seedance Video",
      "description": "Seedance series video generation capability"
    }
  ],
  "paths": {
    "/v1/videos": {
      "post": {
        "summary": "Seedance 2.0 Text-to-Video",
        "description": "dreamina-seedance-2-0-260128\n\nApplicable to the `dreamina-seedance-2-0-260128` model. After submitting a task, please query the status via `GET /v1/videos/{task_id}`.",
        "operationId": "seedance20TextToVideoEn",
        "tags": [
          "Seedance Video"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextToVideoRequest"
              },
              "examples": {
                "text_to_video": {
                  "summary": "Basic text-to-video",
                  "value": {
                    "model": "dreamina-seedance-2-0-260128",
                    "media": [
                      {
                        "type": "text",
                        "text": "A small cat running on the grass, sunny day, camera following the movement"
                      }
                    ],
                    "seconds": "5",
                    "size": "720p",
                    "ratio": "16:9",
                    "generate_audio": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission successful, returns a video task object.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoTaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters."
          },
          "401": {
            "description": "Authentication failed."
          },
          "500": {
            "description": "Internal server error."
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "TextToVideoRequest": {
        "type": "object",
        "required": [
          "model",
          "media"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "dreamina-seedance-2-0-260128"
            ],
            "description": "Video generation model name. Fixed to `dreamina-seedance-2-0-260128`."
          },
          "media": {
            "type": "array",
            "minItems": 1,
            "description": "Multimodal input array. 2.0 supports `text`, `first_frame`, `last_frame`, `reference_image`, `reference_video`, `reference_audio`.",
            "items": {
              "$ref": "#/components/schemas/VideoMediaInput"
            }
          },
          "seconds": {
            "type": "string",
            "description": "Video generation duration (seconds) as a string. Supports `\"-1\"` (smart selection) or `\"4\"` to `\"15\"`.",
            "default": "5",
            "example": "5",
            "enum": [
              "4",
              "5",
              "6",
              "7",
              "8",
              "9",
              "10",
              "11",
              "12",
              "15",
              "-1"
            ]
          },
          "size": {
            "type": "string",
            "enum": [
              "480p",
              "720p"
            ],
            "description": "Video output resolution specification. Defaults to 720p.",
            "default": "720p"
          },
          "ratio": {
            "type": "string",
            "enum": [
              "16:9",
              "4:3",
              "1:1",
              "3:4",
              "9:16",
              "21:9",
              "adaptive"
            ],
            "description": "Video aspect ratio. Text-to-Video defaults to 16:9, first-frame Image-to-Video defaults to `adaptive`.",
            "default": "16:9"
          },
          "seed": {
            "type": "integer",
            "description": "Random seed, range [-1, 4294967295].",
            "default": -1,
            "minimum": -1,
            "maximum": 4294967295
          },
          "watermark": {
            "type": "boolean",
            "description": "Whether to add a watermark.",
            "default": false
          },
          "generate_audio": {
            "type": "boolean",
            "description": "Whether to generate sound synchronized with the image. Supported by the 2.0 series.",
            "default": true
          },
          "safety_identifier": {
            "type": "string",
            "description": "Unique terminal user identifier for compliance detection. Only supported by the 2.0 series, length not exceeding 64 characters."
          }
        }
      },
      "VideoMediaInput": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "text"
            ],
            "description": "Media type. `text` requires the `text` field; other types require the `url` field."
          },
          "text": {
            "type": "string",
            "description": "Text content. Required when `type=text`; not required for other types."
          }
        }
      },
      "VideoTaskResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "task_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "description": "Task status."
          }
        }
      }
    }
  }
}