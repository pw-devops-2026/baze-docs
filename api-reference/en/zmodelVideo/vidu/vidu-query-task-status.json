{
  "openapi": "3.0.1",
  "info": {
    "title": "Vidu Task Status Query",
    "version": "1.0.0",
    "description": "Unified task status query interface for Vidu. Applicable to all types of tasks including video, audio, and image generation."
  },
  "servers": [
    {
      "url": "https://baze-api.powerbuyin.top",
      "description": "Baze API Service Endpoint"
    }
  ],
  "paths": {
    "/vidu/v1/tasks/{task_id}": {
      "get": {
        "summary": "Task Status Query",
        "operationId": "viduQueryTaskStatus",
        "description": "Query the latest status of a Vidu task by task ID.\n\n**Supported Task Types:**\n- Video tasks (text-to-video, image-to-video, reference-to-video, start-end-to-video)\n- Audio tasks (text-to-audio, timing-to-audio)\n- Image tasks (reference-to-image)\n\n**Task States:**\n- **created**: Task created successfully\n- **queueing**: Task in queue\n- **processing**: Task processing\n- **success**: Generation successful\n- **failed**: Task failed\n\nAfter task completion, call the corresponding download endpoint based on task type to retrieve result files.",
        "tags": [
          "Vidu Tasks"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Task ID returned by the task creation endpoint."
          }
        ],
        "responses": {
          "200": {
            "description": "Query successful, returns task status information.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskStatusResponse"
                },
                "examples": {
                  "video_task_processing": {
                    "summary": "Video task processing",
                    "value": {
                      "task_id": "vid_abc123def456",
                      "state": "processing",
                      "model": "viduq3-pro",
                      "prompt": "A kitten running on grass, sunny day",
                      "duration": 5,
                      "resolution": "720p",
                      "progress": 45,
                      "credits": 10,
                      "created_at": "2025-01-01T15:41:31.968916Z"
                    }
                  },
                  "audio_task_completed": {
                    "summary": "Audio task completed",
                    "value": {
                      "task_id": "aud_xyz789",
                      "state": "success",
                      "model": "audio1.0",
                      "prompt": "Sound of raindrops falling on window",
                      "duration": 10,
                      "credits": 5,
                      "created_at": "2025-01-01T15:40:00.000000Z",
                      "completed_at": "2025-01-01T15:41:30.000000Z"
                    }
                  },
                  "image_task_failed": {
                    "summary": "Image task failed",
                    "value": {
                      "task_id": "img_def456ghi789",
                      "state": "failed",
                      "model": "viduq2",
                      "prompt": "A beautiful sunset scene",
                      "error_message": "Error occurred during generation",
                      "credits": 0,
                      "created_at": "2025-01-01T15:30:00.000000Z"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Task not found or expired.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "not_found": {
                    "summary": "Task not found",
                    "value": {
                      "code": "task_not_found",
                      "message": "Task not found or has expired",
                      "data": null
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "unauthorized": {
                    "summary": "Unauthorized",
                    "value": {
                      "code": "access_denied",
                      "message": "Invalid token",
                      "data": null
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "server_error": {
                    "summary": "Server error",
                    "value": {
                      "code": "internal_server_error",
                      "message": "Internal server error, please try again later",
                      "data": null
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "TaskStatusResponse": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "description": "Task ID."
          },
          "state": {
            "type": "string",
            "enum": [
              "created",
              "queueing",
              "processing",
              "success",
              "failed"
            ],
            "description": "Task processing state:\n- **created**: Task created successfully\n- **queueing**: Task in queue\n- **processing**: Task processing\n- **success**: Generation successful\n- **failed**: Task failed"
          },
          "model": {
            "type": "string",
            "description": "Model name used."
          },
          "prompt": {
            "type": "string",
            "description": "Text prompt (if applicable)."
          },
          "images": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Input images list (if applicable)."
          },
          "duration": {
            "type": "integer",
            "description": "Duration parameter (seconds), used for video and audio tasks."
          },
          "seed": {
            "type": "integer",
            "description": "Random seed (if applicable)."
          },
          "resolution": {
            "type": "string",
            "description": "Resolution parameter (if applicable)."
          },
          "aspect_ratio": {
            "type": "string",
            "description": "Aspect ratio parameter (if applicable)."
          },
          "progress": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "Task progress percentage (0-100), only returned when state is processing."
          },
          "credits": {
            "type": "integer",
            "description": "Credits consumed."
          },
          "error_message": {
            "type": "string",
            "description": "Error message, only returned when state is failed."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Task creation time (ISO 8601 format)."
          },
          "completed_at": {
            "type": "string",
            "format": "date-time",
            "description": "Task completion time (ISO 8601 format), only returned when state is success or failed."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code."
          },
          "message": {
            "type": "string",
            "description": "Error description message."
          },
          "data": {
            "type": "object",
            "nullable": true,
            "description": "Additional error data (optional)."
          }
        }
      }
    }
  }
}
