{
  "openapi": "3.0.1",
  "info": {
    "title": "Kling Omni Image Task - Query Task Status",
    "version": "1.0.0",
    "description": "Query Kling native omni image task status via `/kling/v1/images/omni-image/{task_id}`."
  },
  "servers": [
    {
      "url": "https://baze-api.powerbuyin.top",
      "description": ""
    }
  ],
  "tags": [
    {
      "name": "Kling",
      "description": "Kling native async task endpoints"
    }
  ],
  "paths": {
    "/kling/v1/images/omni-image/{task_id}": {
      "get": {
        "summary": "Query Kling task status",
        "description": "Returns the persisted Kling native task response. The task_id path parameter is the public task ID returned by the submission endpoint.",
        "operationId": "createKlingOmniImageStatus",
        "tags": [
          "Kling"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "description": "Image generation task ID. Path parameter, place the value directly in the request path. Choose either this or external_task_id for querying.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Task status response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FetchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Task does not exist or cannot be queried.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer token.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Pass `Authorization: Bearer <token>` in the request header."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "description": "Error details returned by the gateway or upstream provider."
          }
        }
      },
      "FetchResponse": {
        "type": "object",
        "required": [
          "code",
          "message",
          "data"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "description": "Kling response code."
          },
          "message": {
            "type": "string",
            "description": "Kling response message."
          },
          "request_id": {
            "type": "string",
            "description": "Upstream request identifier (if provided)."
          },
          "data": {
            "type": "object",
            "properties": {
              "task_id": {
                "type": "string",
                "description": "Public task ID generated by this gateway."
              },
              "task_status": {
                "type": "string",
                "enum": [
                  "submitted",
                  "processing",
                  "succeed",
                  "failed"
                ],
                "description": "Current task status."
              },
              "task_status_msg": {
                "type": "string",
                "description": "Failure or progress message from Kling."
              },
              "task_info": {
                "type": "object",
                "description": "Task metadata. The gateway does not expose the upstream task ID."
              },
              "task_result": {
                "type": "object",
                "description": "Kling task result. Video endpoints return video; image endpoints return images and may also return series_images."
              },
              "final_unit_deduction": {
                "type": "string",
                "description": "Upstream cost reference value, retained for audit purposes only and not used for user billing quota."
              },
              "created_at": {
                "type": "integer",
                "format": "int64",
                "description": "Creation time in milliseconds."
              },
              "updated_at": {
                "type": "integer",
                "format": "int64",
                "description": "Update time in milliseconds."
              }
            }
          }
        }
      }
    }
  }
}
