{
  "openapi": "3.0.1",
  "info": {
    "title": "Seedance Video Generation",
    "version": "1.0.0",
    "description": "Video capability documentation for the Seedance model family. The public endpoint is `/v1/videos` and creates asynchronous generation tasks.",
    "license": {
      "name": "Project License",
      "url": "https://github.com/QuantumNous/new-api/blob/main/LICENSE"
    }
  },
  "servers": [
    {
      "url": "https://baze-api.powerbuyin.top",
      "description": "Baze API service endpoint"
    }
  ],
  "tags": [
    {
      "name": "Seedance Video",
      "description": "Video generation capabilities for Seedance models"
    }
  ],
  "paths": {
    "/v1/videos": {
      "post": {
        "summary": "Seedance Video Generation",
        "description": "For Seedance video models. After submission, query task status with `GET /v1/videos/{task_id}`.\n\nThe currently documented public workflows are text-to-video and first-frame image-to-video. This document covers `model`, `prompt`, `image`, `seconds`, `size`, `ratio`, `seed`, `camera_fixed`, `watermark`, `generate_audio`, `draft`, and `return_last_frame`. `size` is the public output tier and billing field.",
        "operationId": "byteplusVideoGenerations",
        "tags": [
          "Seedance Video"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VideoGenerationRequest"
              },
              "examples": {
                "text_to_video": {
                  "summary": "Text to video",
                  "value": {
                    "model": "seedance-1-5-pro-251215",
                    "prompt": "A kitten running on grass, sunny day, camera following",
                    "seconds": 5,
                    "size": "720p",
                    "ratio": "16:9",
                    "generate_audio": true
                  }
                },
                "image_to_video": {
                  "summary": "First frame to video",
                  "value": {
                    "model": "seedance-1-5-pro-251215",
                    "prompt": "Camera slowly pushing in, girl smiling",
                    "image": "https://example.com/first-frame.jpg",
                    "seconds": 5,
                    "size": "720p",
                    "ratio": "adaptive"
                  }
                },
                "draft_mode": {
                  "summary": "Draft mode (fast preview)",
                  "value": {
                    "model": "seedance-1-5-pro-251215",
                    "prompt": "Dog playing with ball",
                    "draft": true,
                    "size": "480p"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission successful, returns video task object.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoTaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "invalid_request": {
                    "summary": "Bad request",
                    "value": {
                      "error": {
                        "message": "Request body is invalid or contains unsupported values",
                        "type": "invalid_request_error",
                        "code": "bad_request_body",
                        "param": ""
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "unauthorized": {
                    "summary": "Unauthorized",
                    "value": {
                      "error": {
                        "message": "Invalid token",
                        "type": "api_error",
                        "code": "access_denied",
                        "param": ""
                      }
                    }
                  }
                }
              }
            },
            "description": "Authentication failed, for example because the token is missing or invalid."
          },
          "413": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "request_too_large": {
                    "summary": "Request body too large",
                    "value": {
                      "error": {
                        "message": "Request body is too large; reduce the input and try again",
                        "type": "api_error",
                        "code": "read_request_body_failed",
                        "param": ""
                      }
                    }
                  }
                }
              }
            },
            "description": "The request body is too large."
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "quota_exceeded": {
                    "summary": "Quota exceeded or rate limited",
                    "value": {
                      "error": {
                        "message": "Insufficient quota for this request",
                        "type": "api_error",
                        "code": "insufficient_user_quota",
                        "param": ""
                      }
                    }
                  }
                }
              }
            },
            "description": "Rate limits were hit or the account ran out of quota."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "internal_error": {
                    "summary": "Internal processing error",
                    "value": {
                      "error": {
                        "message": "Internal request processing failed",
                        "type": "api_error",
                        "code": "gen_relay_info_failed",
                        "param": ""
                      }
                    }
                  }
                }
              }
            },
            "description": "The server failed while processing the request."
          },
          "502": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "bad_gateway": {
                    "summary": "Invalid service response",
                    "value": {
                      "error": {
                        "message": "The model service returned an invalid response",
                        "type": "api_error",
                        "code": "bad_response_status_code",
                        "param": ""
                      }
                    }
                  }
                }
              }
            },
            "description": "The model service returned an invalid response."
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "service_unavailable": {
                    "summary": "Service unavailable",
                    "value": {
                      "error": {
                        "message": "No available channel for the requested model",
                        "type": "api_error",
                        "code": "get_channel_failed",
                        "param": ""
                      }
                    }
                  }
                }
              }
            },
            "description": "The model service is temporarily unavailable, or the requested model is not currently available."
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "VideoGenerationRequest": {
        "type": "object",
        "required": [
          "model",
          "prompt"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "seedance-1-5-pro-251215",
              "seedance-1-0-pro-250528",
              "seedance-1-0-pro-fast-251015"
            ],
            "description": "Video generation model name. Supported models include `seedance-1-5-pro-251215`, `seedance-1-0-pro-250528`, and `seedance-1-0-pro-fast-251015`. All three support text-to-video and first-frame image-to-video. `seedance-1-5-pro-251215` additionally supports `generate_audio`, `draft`, and `return_last_frame`."
          },
          "prompt": {
            "type": "string",
            "description": "Text prompt describing desired video content. Recommended max 500 Chinese characters or 1000 English words."
          },
          "image": {
            "type": "string",
            "description": "First-frame image URL or Base64-encoded input for first-frame image-to-video."
          },
          "seconds": {
            "type": "integer",
            "description": "Video duration in seconds. 1.5-pro supports 4-12 seconds or -1 (auto-select); other models support 2-12 seconds.",
            "minimum": -1,
            "maximum": 12,
            "default": 5
          },
          "size": {
            "type": "string",
            "enum": [
              "480p",
              "720p",
              "1080p"
            ],
            "description": "Public output size tier and billing field. Draft mode only supports 480p. 1.5-pro defaults to 720p, while 1.0-pro and 1.0-pro-fast default to 1080p."
          },
          "ratio": {
            "type": "string",
            "enum": [
              "16:9",
              "4:3",
              "1:1",
              "3:4",
              "9:16",
              "21:9",
              "adaptive"
            ],
            "description": "Video aspect ratio. Text-to-video defaults to 16:9 (`seedance-1-5-pro-251215` defaults to `adaptive`), while first-frame image-to-video defaults to `adaptive`.",
            "default": "16:9"
          },
          "seed": {
            "type": "integer",
            "description": "Random seed, range [-1, 4294967295].",
            "default": -1
          },
          "camera_fixed": {
            "type": "boolean",
            "description": "Whether to fix camera.",
            "default": false
          },
          "watermark": {
            "type": "boolean",
            "description": "Whether to add watermark.",
            "default": false
          },
          "generate_audio": {
            "type": "boolean",
            "description": "Whether to generate audio synchronized with video. Only seedance-1.5-pro supports.",
            "default": true
          },
          "draft": {
            "type": "boolean",
            "description": "Whether to enable draft mode. Generates preview video faster but lower quality. Only seedance-1.5-pro supports.",
            "default": false
          },
          "return_last_frame": {
            "type": "boolean",
            "description": "Whether to return last frame image. Can get video last frame via query interface when enabled.",
            "default": false
          }
        }
      },
      "VideoTaskResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "task_id": {
            "type": "string"
          },
          "object": {
            "type": "string",
            "example": "video"
          },
          "model": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "queued",
              "running",
              "succeeded",
              "failed",
              "cancelled",
              "expired"
            ],
            "description": "Task status."
          },
          "progress": {
            "type": "integer"
          },
          "created_at": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "description": "Error type, such as `invalid_request_error` or `api_error`."
              },
              "code": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
