{
  "openapi": "3.0.1",
  "info": {
    "title": "Seedance Video Generation",
    "version": "1.0.0",
    "description": "Video capability documentation for the Seedance model family. The public endpoint is `/v1/videos` and creates asynchronous generation tasks.",
    "license": {
      "name": "Project License",
      "url": "https://github.com/QuantumNous/new-api/blob/main/LICENSE"
    }
  },
  "servers": [
    {
      "url": "https://baze-api.powerbuyin.top",
      "description": "Baze API service endpoint"
    }
  ],
  "tags": [
    {
      "name": "Seedance Video",
      "description": "Video generation capabilities for Seedance models"
    }
  ],
  "paths": {
    "/v1/videos": {
      "post": {
        "summary": "Seedance Video Generation",
        "description": "For Seedance video models. After submission, query task status with `GET /v1/videos/{task_id}`.\n\nSupports text-to-video, first-frame image-to-video, first-and-last-frame video, and reference-image video workflows. Public fields: `model`, `prompt`, `image`, `seconds`, `size`, `resolution`, `ratio`, `seed`, `camera_fixed`, `watermark`, `generate_audio`, and `draft`.",
        "operationId": "byteplusVideoGenerations",
        "tags": [
          "Seedance Video"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VideoGenerationRequest"
              },
              "examples": {
                "text_to_video": {
                  "summary": "Text to video",
                  "value": {
                    "model": "doubao-seedance-1.5-pro-251215",
                    "prompt": "A kitten running on grass, sunny day, camera following",
                    "seconds": 5,
                    "resolution": "720p",
                    "ratio": "16:9",
                    "generate_audio": true
                  }
                },
                "image_to_video": {
                  "summary": "First frame to video",
                  "value": {
                    "model": "doubao-seedance-1.5-pro-251215",
                    "prompt": "Camera slowly pushing in, girl smiling",
                    "image": "https://example.com/first-frame.jpg",
                    "seconds": 5,
                    "resolution": "720p",
                    "ratio": "adaptive"
                  }
                },
                "first_last_frame": {
                  "summary": "First and last frame to video",
                  "value": {
                    "model": "doubao-seedance-1.5-pro-251215",
                    "prompt": "Person transitioning from standing to sitting",
                    "image": "https://example.com/first.jpg",
                    "last_frame_url": "https://example.com/last.jpg",
                    "seconds": 5
                  }
                },
                "draft_mode": {
                  "summary": "Draft mode (fast preview)",
                  "value": {
                    "model": "doubao-seedance-1.5-pro-251215",
                    "prompt": "Dog playing with ball",
                    "draft": true,
                    "resolution": "480p"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission successful, returns video task object.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoTaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "VideoGenerationRequest": {
        "type": "object",
        "required": [
          "model",
          "prompt"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "doubao-seedance-1.5-pro-251215",
              "doubao-seedance-1.0-pro-250528",
              "doubao-seedance-1.0-pro-fast-251015",
              "doubao-seedance-1.0-lite-t2v-250428",
              "doubao-seedance-1.0-lite-i2v-250428"
            ],
            "description": "Video generation model name. 1.5-pro supports all modes; 1.0-pro supports text-to-video/first-frame/first-last-frame; 1.0-pro-fast supports text-to-video/first-frame only; 1.0-lite-t2v is text-to-video only; 1.0-lite-i2v supports all modes."
          },
          "prompt": {
            "type": "string",
            "description": "Text prompt describing desired video content. Recommended max 500 Chinese characters or 1000 English words."
          },
          "image": {
            "anyOf": [
              {
                "type": "string",
                "description": "Single image URL (first frame or reference)."
              },
              {
                "type": "array",
                "description": "Multiple reference images (1-4) for reference-image-to-video.",
                "items": {
                  "type": "string"
                }
              }
            ],
            "description": "Input images for image-to-video scenarios."
          },
          "last_frame_url": {
            "type": "string",
            "description": "Last frame image URL. For first-and-last-frame-to-video. Supported by 1.5-pro, 1.0-pro, 1.0-lite-i2v."
          },
          "seconds": {
            "type": "integer",
            "description": "Video duration in seconds. 1.5-pro supports 4-12 seconds or -1 (auto-select); other models support 2-12 seconds.",
            "minimum": -1,
            "maximum": 12,
            "default": 5
          },
          "resolution": {
            "type": "string",
            "enum": [
              "480p",
              "720p",
              "1080p"
            ],
            "description": "Video resolution. seedance-1.0-lite doesn't support 1080p; draft mode only supports 480p. 1.5-pro/1.0-lite default 720p, 1.0-pro/pro-fast default 1080p."
          },
          "size": {
            "type": "string",
            "description": "Same as resolution, for OpenAI compatibility."
          },
          "ratio": {
            "type": "string",
            "enum": [
              "16:9",
              "4:3",
              "1:1",
              "3:4",
              "9:16",
              "21:9",
              "adaptive"
            ],
            "description": "Video aspect ratio. Text-to-video defaults to 16:9 (1.5-pro defaults to adaptive); image-to-video defaults to adaptive. Reference-image scenario doesn't support adaptive.",
            "default": "16:9"
          },
          "seed": {
            "type": "integer",
            "description": "Random seed, range [-1, 4294967295].",
            "default": -1
          },
          "camera_fixed": {
            "type": "boolean",
            "description": "Whether to fix camera. Reference-image scenario doesn't support this.",
            "default": false
          },
          "watermark": {
            "type": "boolean",
            "description": "Whether to add watermark.",
            "default": false
          },
          "generate_audio": {
            "type": "boolean",
            "description": "Whether to generate audio synchronized with video. Only seedance-1.5-pro supports.",
            "default": true
          },
          "draft": {
            "type": "boolean",
            "description": "Whether to enable draft mode. Generates preview video faster but lower quality. Only seedance-1.5-pro supports.",
            "default": false
          },
          "return_last_frame": {
            "type": "boolean",
            "description": "Whether to return last frame image. Can get video last frame via query interface when enabled.",
            "default": false
          }
        }
      },
      "VideoTaskResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "task_id": {
            "type": "string"
          },
          "object": {
            "type": "string",
            "example": "video"
          },
          "model": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "queued",
              "running",
              "succeeded",
              "failed",
              "cancelled",
              "expired"
            ],
            "description": "Task status."
          },
          "progress": {
            "type": "integer"
          },
          "created_at": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "code": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
