{
  "openapi": "3.0.1",
  "info": {
    "title": "Wan First-and-Last-Frame to Video",
    "version": "1.0.0",
    "description": "First-and-last-frame image-to-video documentation for Wan models. The public endpoint is `/v1/videos` and creates asynchronous generation tasks.",
    "license": {
      "name": "Project License",
      "url": "https://github.com/QuantumNous/new-api/blob/main/LICENSE"
    }
  },
  "servers": [
    {
      "url": "https://baze-api.powerbuyin.top",
      "description": "Baze API service endpoint"
    }
  ],
  "tags": [
    {
      "name": "Wan Video",
      "description": "First-and-last-frame video capabilities for Wan models"
    }
  ],
  "paths": {
    "/v1/videos": {
      "post": {
        "summary": "Wan First-and-Last-Frame to Video",
        "description": "For Wan first-and-last-frame video models. After submission, query task status with `GET /v1/videos/{task_id}`.\n\nPublic fields: `model`, `image`, `last_frame_url`, `prompt`, `seconds`, `size`, `resolution`, `prompt_extend`, `watermark`, `seed`, and `negative_prompt`. The first frame sets the base composition, and the last frame guides the ending shot.",
        "operationId": "aliFirstLastFrameToVideo",
        "tags": [
          "Wan Video"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FirstLastFrameVideoRequest"
              },
              "examples": {
                "first_last_frame_video": {
                  "summary": "First and last frame to video",
                  "value": {
                    "model": "wan2.2-kf2v-flash",
                    "image": "https://example.com/first-frame.png",
                    "last_frame_url": "https://example.com/last-frame.png",
                    "prompt": "Realistic style, a black kitten curiously looking at the sky, camera moving up from eye level to top-down",
                    "seconds": 5,
                    "resolution": "720P",
                    "prompt_extend": true
                  }
                },
                "with_negative_prompt": {
                  "summary": "With negative prompt",
                  "value": {
                    "model": "wan2.1-kf2v-plus",
                    "image": "https://example.com/first-frame.png",
                    "last_frame_url": "https://example.com/last-frame.png",
                    "prompt": "Cat running from grass to garden",
                    "negative_prompt": "people",
                    "resolution": "720P",
                    "prompt_extend": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission successful, returns video task object.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoTaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/v1/videos/{task_id}": {
      "get": {
        "summary": "Query Ali Video Generation Task Status",
        "description": "Query video generation task status and results by task ID.",
        "operationId": "aliQueryFirstLastVideoStatus",
        "tags": [
          "Ali Video"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Video generation task ID."
          }
        ],
        "responses": {
          "200": {
            "description": "Query successful, returns task status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoTaskQueryResponse"
                }
              }
            }
          },
          "404": {
            "description": "Task not found or expired.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "FirstLastFrameVideoRequest": {
        "type": "object",
        "required": [
          "model",
          "image",
          "last_frame_url"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "wan2.2-kf2v-flash",
              "wan2.1-kf2v-plus"
            ],
            "description": "Wanxiang first-and-last-frame-to-video model."
          },
          "image": {
            "type": "string",
            "description": "First frame image URL. Output video aspect ratio matches first frame."
          },
          "last_frame_url": {
            "type": "string",
            "description": "Last frame image URL. Will be cropped to match first frame's aspect ratio."
          },
          "prompt": {
            "type": "string",
            "description": "Text prompt describing transition from first to last frame. Supports Chinese and English, max 800 characters."
          },
          "seconds": {
            "type": "integer",
            "description": "Video duration in seconds. Currently fixed at 5 seconds.",
            "default": 5
          },
          "resolution": {
            "type": "string",
            "enum": [
              "480P",
              "720P",
              "1080P"
            ],
            "description": "Video resolution. wan2.2-kf2v-flash supports 480P/720P/1080P, wan2.1-kf2v-plus supports 720P only.",
            "default": "720P"
          },
          "size": {
            "type": "string",
            "description": "Same as resolution, for OpenAI compatibility. Options: 480P, 720P, 1080P."
          },
          "prompt_extend": {
            "type": "boolean",
            "description": "Whether to enable prompt intelligent rewriting.",
            "default": true
          },
          "watermark": {
            "type": "boolean",
            "description": "Whether to add watermark to video.",
            "default": false
          },
          "seed": {
            "type": "integer",
            "description": "Random seed, range [0, 2147483647]."
          },
          "negative_prompt": {
            "type": "string",
            "description": "Negative prompt describing content to avoid. Max 500 characters."
          }
        }
      },
      "VideoTaskResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "task_id": {
            "type": "string"
          },
          "object": {
            "type": "string",
            "example": "video"
          },
          "model": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "queued",
              "running",
              "succeeded",
              "failed",
              "cancelled"
            ]
          },
          "progress": {
            "type": "integer"
          },
          "created_at": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "VideoTaskQueryResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "task_id": {
            "type": "string"
          },
          "object": {
            "type": "string",
            "example": "video"
          },
          "model": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "queued",
              "running",
              "succeeded",
              "failed",
              "cancelled"
            ]
          },
          "progress": {
            "type": "integer"
          },
          "created_at": {
            "type": "integer",
            "format": "int64"
          },
          "completed_at": {
            "type": "integer",
            "format": "int64"
          },
          "video_url": {
            "type": "string",
            "description": "Generated video download URL. Valid for 24 hours."
          },
          "metadata": {
            "type": "object",
            "properties": {
              "orig_prompt": {
                "type": "string"
              },
              "actual_prompt": {
                "type": "string"
              },
              "video_duration": {
                "type": "integer"
              },
              "SR": {
                "type": "integer"
              },
              "video_ratio": {
                "type": "string"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "code": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
